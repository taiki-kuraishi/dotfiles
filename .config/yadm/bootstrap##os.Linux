#!/bin/sh
# yadm bootstrap (Linux): roppoh リモート開発 Pod など Linux 環境の初期化。
# macOS 側は bootstrap##os.Darwin(nix-darwin ベース)。ユーザー環境の設定本体は
# 両 OS 共通の Home Manager モジュール(~/.config/nix/home-common.nix)で統一している。
set -e

# 1. CPU アーキから該当の homeConfigurations を選択。
case "$(uname -m)" in
  x86_64 | amd64) sys=x86_64-linux ;;
  aarch64 | arm64) sys=aarch64-linux ;;
  *)
    echo "unsupported arch: $(uname -m)" >&2
    exit 1
    ;;
esac

# 2. Home Manager を適用（home-common.nix）。
#    -b backup: Pod イメージ同梱の ~/.zshrc 等があっても衝突せず退避する。
nix run github:nix-community/home-manager -- \
  switch -b backup --flake "$HOME/.config/nix#$(whoami)-$sys"

# 3. HM 導入物をこのシェルの PATH へ（mise/claude を同一実行内で使えるように）。
export PATH="$HOME/.nix-profile/bin:$PATH"

# 4. mise 管理ツール（~/.config/mise/config.toml に従う。mise 本体は HM 導入済み）。
mise install --yes

# 5. Claude Code(ネイティブバイナリ。~/.local 配下に入り、以後は自己更新される)。
if [ ! -x "$HOME/.local/bin/claude" ]; then
  curl -fsSL https://claude.ai/install.sh | bash
fi

# 6. bunx skills の復元(bun は mise で導入済み。Darwin bootstrap の手順 3 と同等)。
mise x -- bunx skills experimental_install
