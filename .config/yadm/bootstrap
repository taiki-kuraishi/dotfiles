#!/bin/sh
# yadm bootstrap: provision a fresh machine after `yadm clone`.
set -e

# 1. Install upstream (official) Nix if missing, so nix-darwin can manage Nix
#    natively (the Determinate distribution ships its own daemon that conflicts
#    with nix-darwin). The official installer is interactive on macOS, so run it
#    from a file rather than `curl | sh` to keep the terminal on stdin.
if ! command -v nix >/dev/null 2>&1; then
  installer="$(mktemp)"
  curl --proto '=https' --tlsv1.2 -fsSL https://nixos.org/nix/install -o "$installer"
  sh "$installer" --daemon
  rm -f "$installer"
fi

# Make nix available in this (non-login) shell.
if [ -e /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]; then
  . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
fi

# 2. Apply nix-darwin.
#    The Nix installer writes /etc/nix/nix.conf and appends to the shell rc
#    files; nix-darwin manages all of these and refuses to overwrite content it
#    doesn't recognize on first activation. Move them aside (the originals are
#    preserved as *.before-nix-darwin) so nix-darwin can take over.
for f in /etc/nix/nix.conf /etc/bashrc /etc/zshrc; do
  if [ -f "$f" ] && [ ! -e "$f.before-nix-darwin" ]; then
    sudo mv "$f" "$f.before-nix-darwin"
  fi
done
# Use the flake-based first-run form (works before darwin-rebuild is on PATH).
# `env PATH=$PATH` keeps nix on root's PATH under sudo.
# Upstream Nix has flakes/nix-command off by default, so enable them for this
# bootstrap run; nix-darwin's nix.settings.experimental-features makes them
# permanent after the first activation.
# Select the darwinConfiguration by this machine's hostname; it must be
# registered in flake.nix (darwinConfigurations.<hostname>).
HOSTNAME="$(scutil --get LocalHostName)"
sudo env "PATH=$PATH" nix --extra-experimental-features 'nix-command flakes' \
  run nix-darwin/master#darwin-rebuild -- \
  switch --flake "$HOME/.config/nix-darwin#$HOSTNAME"

# 3. Install mise-managed tools.
if command -v mise >/dev/null 2>&1; then
  mise install
fi
