[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[user]
	name = taiki-kuraishi
	email = 131664944+taiki-kuraishi@users.noreply.github.com
[alias]
	a = add
	aa = add --all
	br = branch
	cl = clone
	cm = commit
	cma = commit --amend
	cman = commit --amend --no-edit
	cmanm = commit --amend --no-edit -m
	cmm = commit -m
	co = checkout
	df = diff
	f = fetch
	fpa = fetch --prune --all
	lg = log
	m = merge
	ms = merge --squash
	mo = merge origin
	mso = merge --squash origin
	p = push
	pl = pull
	po = pull origin
	r = reset
	rpo = remote prune origin
	rsh = reset --soft HEAD^
	s = status
	sh = stash
	ss = status --short
	sw = switch
	lg = log --graph --decorate --abbrev-commit --format=format:'%C(blue)%h%C(reset) - %C(green)(%ar)%C(reset)%C(yellow)%d%C(reset)\n  %C(white)%s%C(reset) %C(dim white)- %an%C(reset)'
	empty-commit = commit --allow-empty -m "empty commit"
[ghq]
	root = ~/Documents/ghq
[credential "https://github.com"]
	# デフォルトは個人アカウント (taiki-kuraishi) 固定。
	# gh の標準 helper はアクティブアカウントのトークンしか返さないため、
	# 指定アカウントのトークンを直接取得する。username も明示しないと
	# git がユーザ名を対話プロンプトで要求してしまう点に注意。
	# 会社 org (fancomi-interconnect) 配下は includeIf → ~/.gitconfig-work で上書き。
	username = taiki-kuraishi
	helper =
	helper = "!f() { test \"$1\" = get && printf 'password=%s\\n' \"$(gh auth token --user taiki-kuraishi)\"; }; f"
[credential "https://gist.github.com"]
	username = taiki-kuraishi
	helper =
	helper = "!f() { test \"$1\" = get && printf 'password=%s\\n' \"$(gh auth token --user taiki-kuraishi)\"; }; f"
[include]
	path = ~/.gitconfig.local
[includeIf "gitdir:~/Documents/ghq/github.com/fancomi-interconnect/"]
	path = ~/.gitconfig-work
[includeIf "gitdir:~/Documents/ghq/github.com/a8-engineer/"]
	path = ~/.gitconfig-work
